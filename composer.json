{
    "name": "greph/greph",
    "description": "Pure PHP code search, structural search, and rewrite engine. grep, ripgrep, and ast-grep workflows in a single Composer package.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "inline0",
            "homepage": "https://github.com/inline0"
        }
    ],
    "homepage": "https://github.com/inline0/greph",
    "support": {
        "issues": "https://github.com/inline0/greph/issues",
        "source": "https://github.com/inline0/greph"
    },
    "keywords": [
        "php",
        "grep",
        "ripgrep",
        "ast-grep",
        "code-search",
        "structural-search",
        "refactoring",
        "rewrite",
        "indexed-search",
        "ast"
    ],
    "require": {
        "php": "^8.2",
        "ext-json": "*",
        "nikic/php-parser": "^5.7"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^13.1",
        "squizlabs/php_codesniffer": "^3.10"
    },
    "suggest": {
        "ext-pcntl": "Enables parallel worker pools for text and AST scans. Greph falls back to single-process execution when missing."
    },
    "autoload": {
        "psr-4": {
            "Greph\\": "src/",
            "Greph\\Benchmarks\\": "benchmarks/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Greph\\Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "process-timeout": 0,
        "sort-packages": true
    },
    "bin": [
        "bin/greph",
        "bin/greph-index",
        "bin/rg",
        "bin/sg"
    ],
    "scripts": {
        "test": "phpunit",
        "test:unit": "phpunit --testsuite unit",
        "test:oracle": "php bin/test-regression",
        "test:coverage": "php -d pcov.enabled=1 vendor/bin/phpunit --coverage-text --colors=never",
        "analyse": "phpstan analyse --configuration=phpstan.neon.dist --memory-limit=512M",
        "cs": "phpcs --warning-severity=0",
        "cs:fix": "phpcbf",
        "verify": [
            "@analyse",
            "@cs",
            "@test",
            "@test:oracle"
        ]
    }
}

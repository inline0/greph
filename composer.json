{
    "name": "inline0/phgrep",
    "description": "Pure PHP code search and structural refactoring tool.",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": "^8.2",
        "ext-json": "*",
        "nikic/php-parser": "^5.7"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^11.0",
        "squizlabs/php_codesniffer": "^3.10"
    },
    "autoload": {
        "psr-4": {
            "Phgrep\\": "src/",
            "Phgrep\\Benchmarks\\": "benchmarks/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Phgrep\\Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "process-timeout": 0,
        "sort-packages": true
    },
    "bin": [
        "bin/phgrep",
        "bin/oracle",
        "bin/actual",
        "bin/compare",
        "bin/test-scenario",
        "bin/test-regression",
        "bin/verify-compliance",
        "bin/bench",
        "bin/bench-aggregate",
        "bin/bench-series",
        "bin/bench-compare"
    ],
    "scripts": {
        "test": "phpunit",
        "test:unit": "phpunit --testsuite unit",
        "test:coverage": "php -d pcov.enabled=1 vendor/bin/phpunit --coverage-text --colors=never",
        "test:oracle": "php bin/test-regression",
        "analyse": "phpstan analyse --configuration=phpstan.neon.dist --memory-limit=512M",
        "cs": "phpcs --warning-severity=0",
        "cs:fix": "phpcbf",
        "verify": [
            "@analyse",
            "@cs",
            "@test",
            "@test:oracle"
        ]
    }
}

#!/usr/bin/env php
<?php

declare(strict_types=1);

require __DIR__ . '/_bootstrap.php';

use Greph\Benchmarks\BenchmarkArtifactLocator;
use Greph\Support\CommandRunner;
use Greph\Support\Filesystem;
use Greph\Support\ToolResolver;

$arguments = array_slice($argv, 1);
$repo = 'inline0/phgrep';
$outputDirectory = null;
$runId = null;

while ($arguments !== []) {
    /** @var string $argument */
    $argument = array_shift($arguments);

    switch ($argument) {
        case '--repo':
            $repo = array_shift($arguments) ?: $repo;
            break;
        case '--output-dir':
            $outputDirectory = array_shift($arguments) ?: null;
            break;
        default:
            $runId = $argument;
            break;
    }
}

if (!is_string($runId) || $runId === '') {
    throw new RuntimeException('Usage: bin/bench-run [--repo owner/name] [--output-dir path] <run-id>');
}

$outputDirectory ??= $grephRoot . '/build/benchmarks/runs/' . $runId;
Filesystem::remove($outputDirectory);
Filesystem::ensureDirectory($outputDirectory);

$locator = new BenchmarkArtifactLocator();
$runner = new CommandRunner();
$toolResolver = new ToolResolver();
$artifacts = [
    [
        'name' => $locator->headArtifactName($runId),
        'path' => $outputDirectory . '/head',
    ],
    [
        'name' => $locator->baseArtifactName($runId),
        'path' => $outputDirectory . '/base',
    ],
];

foreach ($artifacts as $artifact) {
    $download = $runner->run([
        ...$toolResolver->githubCli(),
        'run',
        'download',
        $runId,
        '--repo',
        $repo,
        '-n',
        $artifact['name'],
        '-D',
        $artifact['path'],
    ], $grephRoot);

    if (!$download->successful()) {
        throw new RuntimeException(
            trim($download->output()) !== ''
                ? trim($download->output())
                : sprintf('Failed to download benchmark artifact: %s', $artifact['name']),
        );
    }
}

$comparisonPath = $locator->findComparisonReport($outputDirectory);
$headSeriesPath = $locator->findHeadSeries($outputDirectory);
$baseSeriesPath = $locator->findBaseSeries($outputDirectory);
$comparison = file_get_contents($comparisonPath);

if ($comparison === false) {
    throw new RuntimeException(sprintf('Failed to read benchmark comparison report: %s', $comparisonPath));
}

fwrite(STDOUT, sprintf("Run: %s\n", $runId));
fwrite(STDOUT, sprintf("Artifact: %s\n", $outputDirectory));
fwrite(STDOUT, sprintf("Comparison: %s\n", Filesystem::relativePath($grephRoot, $comparisonPath)));
fwrite(STDOUT, sprintf("Head series: %s\n", Filesystem::relativePath($grephRoot, $headSeriesPath)));
fwrite(STDOUT, sprintf("Base series: %s\n\n", Filesystem::relativePath($grephRoot, $baseSeriesPath)));
fwrite(STDOUT, $comparison);

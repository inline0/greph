#!/usr/bin/env php
<?php

declare(strict_types=1);

require __DIR__ . '/_bootstrap.php';

use Greph\Benchmarks\BenchmarkReport;
use Greph\Benchmarks\BenchmarkRunner;
use Greph\Support\Json;

$category = null;
$corpus = null;
$outputPath = null;
$compareTools = [];
$arguments = array_slice($argv, 1);

while ($arguments !== []) {
    /** @var string $argument */
    $argument = array_shift($arguments);

    switch ($argument) {
        case '--category':
            $category = array_shift($arguments) ?: null;
            break;
        case '--corpus':
            $corpus = array_shift($arguments) ?: null;
            break;
        case '--compare':
            $compareTools = array_values(array_filter(explode(',', (string) (array_shift($arguments) ?: ''))));
            break;
        case '--output':
            $outputPath = array_shift($arguments) ?: null;
            break;
    }
}

$results = (new BenchmarkRunner($grephRoot))->run($category, $corpus, $compareTools);

if (is_string($outputPath) && $outputPath !== '') {
    Json::encodeFile($outputPath, array_map(static fn ($result) => $result->toArray(), $results));
}

fwrite(STDOUT, (new BenchmarkReport())->render($results));

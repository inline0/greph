#!/usr/bin/env php
<?php

declare(strict_types=1);

require __DIR__ . '/_bootstrap.php';

use Phgrep\Support\Json;
use Phgrep\Tests\Oracle\ScenarioComparator;
use Phgrep\Tests\Oracle\ScenarioRepository;

$scenarioName = $argv[1] ?? null;

if (!is_string($scenarioName) || $scenarioName === '') {
    fwrite(STDERR, "Usage: compare <scenario-name>\n");
    exit(2);
}

$scenario = (new ScenarioRepository($phgrepRoot))->get($scenarioName);
$comparison = (new ScenarioComparator())->compare($scenario);
Json::encodeFile($scenario->reportPath(), $comparison);
fwrite(STDOUT, json_encode($comparison, JSON_PRETTY_PRINT | JSON_UNESCAPED_SLASHES) . PHP_EOL);

exit(($comparison['expectation']['pass'] ?? false) ? 0 : 1);
